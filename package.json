{
  "name": "concrete-vermin",
  "private": true,
  "version": "2.0.1",
  "description": "Concrete Vermin: Tactical Reforged — pulpy 1979 NYC rail-shooter for the arcade cabinet.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false",
    "typecheck:sim": "tsc -b tsconfig.sim.json --pretty false",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome lint .",
    "check:format": "biome format .",
    "test": "pnpm run test:node && pnpm run test:dom",
    "test:node": "vitest run --config vitest.config.ts",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:browser": "vitest --config vitest.browser.config.ts --browser --run",
    "test:watch": "vitest --config vitest.config.ts",
    "test:e2e": "playwright test",
    "cap:sync": "pnpm run build && pnpm exec cap sync",
    "cap:open:android": "pnpm exec cap open android",
    "cap:open:ios": "pnpm exec cap open ios",
    "cap:run:android": "pnpm exec cap run android",
    "cap:run:ios": "pnpm exec cap run ios",
    "lore:print": "tsx scripts/lore-print.ts",
    "analysis:smoke": "tsx scripts/analysis-cli.ts smoke",
    "analysis:benchmark": "tsx scripts/analysis-cli.ts benchmark",
    "analysis:focus": "tsx scripts/analysis-cli.ts focus",
    "analysis:sweep": "tsx scripts/analysis-cli.ts sweep",
    "analysis:lock:quick": "tsx scripts/analysis-cli.ts lock:quick",
    "analysis:autobalance": "tsx scripts/analysis-cli.ts autobalance",
    "screenshots": "tsx scripts/capture-screenshots.ts",
    "perf:trace": "tsx scripts/perf-trace.ts",
    "pages:smoke": "tsx scripts/pages-smoke.ts"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/screen-orientation": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/big-shoulders-display": "^5.2.5",
    "@fontsource/courier-prime": "^5.2.8",
    "@fontsource/special-elite": "^5.2.8",
    "@pixi/react": "^8.0.5",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toast": "^1.2.15",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "jeep-sqlite": "^2.8.0",
    "koota": "^0.6.6",
    "matter-js": "^0.20.0",
    "pixi.js": "^8.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "seedrandom": "^3.0.5",
    "sql.js": "^1.14.1",
    "tone": "^15.1.22",
    "yuka": "^0.7.8",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@capacitor/cli": "^8.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/matter-js": "^0.20.0",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/seedrandom": "^3.0.8",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "axe-core": "^4.11.3",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "pngjs": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.4"
  }
}
